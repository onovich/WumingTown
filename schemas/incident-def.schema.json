{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wuming.invalid/schemas/incident-def.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "kind",
    "phase",
    "eligibility",
    "pressure",
    "telegraph",
    "outcomes"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "incident"
    },
    "phase": {
      "enum": [
        "day",
        "dusk",
        "night",
        "dawn",
        "any"
      ]
    },
    "eligibility": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "pressure": {
      "type": "object",
      "required": [
        "base",
        "category"
      ],
      "properties": {
        "base": {
          "type": "number",
          "minimum": 0
        },
        "category": {
          "enum": [
            "threat",
            "opportunity",
            "recovery",
            "social",
            "mystery"
          ]
        }
      },
      "additionalProperties": true
    },
    "telegraph": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "outcomes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    }
  }
}
