{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "allowImportingTsExtensions": false,
    "allowSyntheticDefaultImports": false,
    "declaration": true,
    "esModuleInterop": false,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "useUnknownInCatchVariables": true,
    "verbatimModuleSyntax": true,
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@wuming-town/benchmarks": ["packages/benchmarks/src/index.ts"],
      "@wuming-town/content-cli": ["tools/content-cli/src/index.ts"],
      "@wuming-town/content-compiler": ["packages/content-compiler/src/index.ts"],
      "@wuming-town/content-schema": ["packages/content-schema/src/index.ts"],
      "@wuming-town/desktop-electron": ["apps/desktop-electron/src/index.ts"],
      "@wuming-town/foundation": ["packages/foundation/src/index.ts"],
      "@wuming-town/headless-runner": ["tools/headless-runner/src/index.ts"],
      "@wuming-town/persistence": ["packages/persistence/src/index.ts"],
      "@wuming-town/platform": ["packages/platform/src/index.ts"],
      "@wuming-town/renderer-pixi": ["packages/renderer-pixi/src/index.ts"],
      "@wuming-town/sim-core": ["packages/sim-core/src/index.ts"],
      "@wuming-town/sim-protocol": ["packages/sim-protocol/src/index.ts"],
      "@wuming-town/sim-worker": ["packages/sim-worker/src/index.ts"],
      "@wuming-town/testkit": ["packages/testkit/src/index.ts"],
      "@wuming-town/ui-react": ["packages/ui-react/src/index.ts"],
      "@wuming-town/web": ["apps/web/src/index.ts"]
    }
  }
}
