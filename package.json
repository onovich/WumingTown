{
  "name": "wuming-town",
  "private": true,
  "version": "0.0.0",
  "description": "Wuming Town TypeScript monorepo",
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "pnpm": "11.8.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit --project tsconfig.typecheck.json --pretty false",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write \"package.json\" \"pnpm-workspace.yaml\" \"tsconfig*.json\" \".prettierrc.json\" \"eslint.config.mjs\" \"vitest.config.mjs\" \".github/**/*.yml\" \"apps/*/package.json\" \"apps/*/tsconfig.json\" \"apps/*/index.html\" \"apps/*/src/**/*.ts\" \"packages/*/package.json\" \"packages/*/tsconfig.json\" \"packages/*/src/**/*.ts\" \"tools/*/package.json\" \"tools/*/tsconfig.json\" \"tools/*/src/**/*.ts\" \"tools/boundary-check.mjs\" \"tools/content-validation.mjs\" \"coordination/decisions/ADR-0001.md\" \"coordination/decisions/ADR-0002.md\" \"coordination/reports/WM-0002*.md\" \"coordination/reports/WM-0003*.md\" \"docs/05_tech/07_architecture_decision_records.md\"",
    "format:check": "prettier --check \"package.json\" \"pnpm-workspace.yaml\" \"tsconfig*.json\" \".prettierrc.json\" \"eslint.config.mjs\" \"vitest.config.mjs\" \".github/**/*.yml\" \"apps/*/package.json\" \"apps/*/tsconfig.json\" \"apps/*/index.html\" \"apps/*/src/**/*.ts\" \"packages/*/package.json\" \"packages/*/tsconfig.json\" \"packages/*/src/**/*.ts\" \"tools/*/package.json\" \"tools/*/tsconfig.json\" \"tools/*/src/**/*.ts\" \"tools/boundary-check.mjs\" \"tools/content-validation.mjs\" \"coordination/decisions/ADR-0001.md\" \"coordination/decisions/ADR-0002.md\" \"coordination/reports/WM-0002*.md\" \"coordination/reports/WM-0003*.md\" \"docs/05_tech/07_architecture_decision_records.md\"",
    "test": "node tools/test-runner.mjs unit",
    "test:sim-core": "node tools/test-runner.mjs unit --filter sim-core",
    "test:sim-protocol": "node tools/test-runner.mjs unit --filter sim-protocol",
    "test:e2e": "pnpm exec playwright install chromium && node tools/test-runner.mjs e2e",
    "sim:run": "node --experimental-strip-types --import ./tools/register-ts-extension-loader.mjs tools/headless-runner/src/cli.ts",
    "sim:replay-test": "node --experimental-strip-types --import ./tools/register-ts-extension-loader.mjs tools/sim-replay-test.mjs",
    "bench": "node --experimental-strip-types --import ./tools/register-ts-extension-loader.mjs packages/benchmarks/src/cli.ts",
    "content:validate": "node tools/content-validation.mjs",
    "boundaries:check": "node tools/boundary-check.mjs",
    "quality": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm content:validate && pnpm boundaries:check && pnpm test",
    "handoff:validate": "node tools/validate-handoff.mjs",
    "coord:validate": "node .agents/skills/wuming-town-agent-workflow/scripts/taskctl.mjs validate",
    "coord:status": "node .agents/skills/wuming-town-agent-workflow/scripts/taskctl.mjs status",
    "coord:route": "node .agents/skills/wuming-town-agent-workflow/scripts/taskctl.mjs route"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "playwright": "1.61.1",
    "prettier": "3.8.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.1.0",
    "vitest": "4.1.9"
  }
}
